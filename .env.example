NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
FAMILY_CHAT_SLUG=family
FAMILY_CHAT_SESSION_SECRET=replace-with-a-long-random-secret
FAMILY_CHAT_AUTH_PEPPER=replace-with-a-long-random-pepper
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Server-side base URL for the Cloudflare Worker media proxy,
# for example https://family-chat-media.<account>.workers.dev.
# Leave empty to use the temporary Supabase Storage fallback in /api/images.
MEDIA_PROXY_BASE_URL=

# Public photo upload endpoint for the Cloudflare Worker media proxy,
# for example https://family-chat-media.<account>.workers.dev/upload.
# Leave empty to keep the current Supabase signed upload fallback.
NEXT_PUBLIC_MEDIA_UPLOAD_URL=

# Shared HMAC secret used by the Next.js app and Cloudflare Worker.
MEDIA_TOKEN_SECRET=
